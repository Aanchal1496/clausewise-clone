{
  "build": {
    "builder": "NIXPACKS",
    "nixPacks": {
      "phases": {
        "install": {
          "cmds": ["pip install --no-cache-dir -r requirements.txt"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "gunicorn app:app --timeout 300 --workers 1 --log-level debug",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
